{
  "name": "rma-onboarding-microservice",
  "version": "0.0.1",
  "engines": {
    "node": ">=16.0.0"
  },
  "description": "\"rma onbaording microservice\"",
  "main": "server.ts",
  "scripts": {
    "build": "npx tsc",
    "start": "node  dist/app.js",
    "dev": "set NODE_OPTIONS=--use-system-ca && nodemon --exec ts-node-dev --respawn src/app.ts",
    "dev2": "nodemon src/app.ts",
    "migrateonly": "npx sequelize-cli db:migrate",
    "migrateundo": "npx sequelize-cli db:migrate:undo",
    "migrate": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate",
    "postmigrate": "npx sequelize-cli db:seed:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CDASolutions/rma-onboarding-microservice.git"
  },
  "keywords": [
    "RMA",
    "microservice",
    "onboarding",
    "nodejs"
  ],
  "author": "Don Prolad, Themba Makamu, Wayne Brough, Lourens Botha",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CDASolutions/rma-onboarding-microservice/issues"
  },
  "homepage": "https://github.com/CDASolutions/rma-onboarding-microservice#readme",
  "dependencies": {
    "@azure/msal-browser": "^3.30.0",
    "@azure/storage-blob": "^12.29.1",
    "auth0": "^4.37.0",
    "axios": "^1.13.2",
    "cls": "^0.1.5",
    "cls-hooked": "^4.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-fileupload": "^1.5.2",
    "express-oauth2-jwt-bearer": "^1.7.1",
    "jsdoc": "^4.0.5",
    "json-rules-engine": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.10.1",
    "openid-client": "^5.7.1",
    "pg": "^8.16.3",
    "qs": "^6.14.0",
    "sequelize": "^6.37.7",
    "tedious": "^18.6.2",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "winston-transport-sequelize": "^4.0.10",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-fileupload": "^1.5.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^18.19.130",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "sequelize-cli": "^6.6.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.9.5",
    "typescript-eslint": "^0.0.1-alpha.0"
  }
}
