{
  "version": 2,
  "builds": [
    {
      "src": "Client%20Connect%20FrontEnd/package.json",
      "use": "@vercel/next@latest",
      "config": {
        "zeroConfig": true
      }
    },
    {
      "src": "Broker-Portal-Frontend/package.json",
      "use": "@vercel/next@latest",
      "config": {
        "zeroConfig": true
      }
    }
  ],
  "routes": [
    {
      "src": "/broker(/?|/.*)",
      "dest": "/Broker-Portal-Frontend$1"
    },
    {
      "src": "/(.*)",
      "dest": "/Client%20Connect%20FrontEnd/$1"
    }
  ]
}
